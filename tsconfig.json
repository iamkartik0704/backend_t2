{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ES2022",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    
    // 🛑 The Fix: Turn off declaration mapping and enforce no file emission
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": true
  }
}